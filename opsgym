#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_DIR="$ROOT_DIR/skills/opsgym/scripts"
NODE_BIN="${NODE_BIN:-node}"

node_major="$("$NODE_BIN" -p 'Number(process.versions.node.split(".")[0])' 2>/dev/null || echo 0)"
if [[ "$node_major" -lt 18 && -x "$HOME/.nvm/versions/node/v24.2.0/bin/node" ]]; then
  NODE_BIN="$HOME/.nvm/versions/node/v24.2.0/bin/node"
fi

usage() {
  cat <<'EOF'
OpsGym CLI

Usage:
  ./opsgym init --question <text> [--arena <id>] [--project <id>]
  ./opsgym list
  ./opsgym status
  ./opsgym next [--yes]
  ./opsgym loop [--yes] [--max-iterations <n>]
  ./opsgym compare --baseline <run-id> --candidate <run-id>
  ./opsgym agent-brief [--arena <id>] [--run <id>] [--agents <n>]
  ./opsgym agent-validate --file <agents.json>
  ./opsgym agent-run [--arena <id>] [--run <id>] [--agents <n>] [--model <model>] [--agents-file <path>]
  ./opsgym doctor [--skip-smoke]
  ./opsgym setup [--arena <id>] [--question <text>] [--mode fast|guided]
  ./opsgym confirm [--arena <id>]
  ./opsgym env [--arena <id>]
  ./opsgym shock [--arena <id>] --type <shock> [--day <n>] [--severity <0..1>]
  ./opsgym run [--arena <id>] [--run <id>] [--rollouts <n>]
  ./opsgym demo
EOF
}

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  init)
    "$NODE_BIN" "$SCRIPT_DIR/init-config.mjs" "$@"
    ;;
  list)
    "$NODE_BIN" "$SCRIPT_DIR/list-adapters.mjs" "$@"
    ;;
  status)
    "$NODE_BIN" "$SCRIPT_DIR/status.mjs" "$@"
    ;;
  next)
    "$NODE_BIN" "$SCRIPT_DIR/next.mjs" "$@"
    ;;
  loop)
    "$NODE_BIN" "$SCRIPT_DIR/loop.mjs" "$@"
    ;;
  compare)
    "$NODE_BIN" "$SCRIPT_DIR/compare-runs.mjs" "$@"
    ;;
  agent-brief|agents-brief)
    "$NODE_BIN" "$SCRIPT_DIR/create-agent-brief.mjs" "$@"
    ;;
  agent-validate|agents-validate|validate-agents)
    "$NODE_BIN" "$SCRIPT_DIR/validate-agent-plans.mjs" "$@"
    ;;
  agent-run|agents)
    "$NODE_BIN" "$SCRIPT_DIR/create-env.mjs" "$@"
    "$NODE_BIN" "$SCRIPT_DIR/run-agent-tournament.mjs" "$@"
    ;;
  doctor)
    "$NODE_BIN" "$SCRIPT_DIR/doctor.mjs" "$@"
    ;;
  setup)
    "$NODE_BIN" "$SCRIPT_DIR/setup-arena.mjs" "$@"
    ;;
  confirm)
    "$NODE_BIN" "$SCRIPT_DIR/confirm-arena.mjs" "$@"
    ;;
  env|prepare)
    "$NODE_BIN" "$SCRIPT_DIR/create-env.mjs" "$@"
    ;;
  shock)
    "$NODE_BIN" "$SCRIPT_DIR/add-shock.mjs" "$@"
    ;;
  run)
    "$NODE_BIN" "$SCRIPT_DIR/create-env.mjs" "$@"
    "$NODE_BIN" "$SCRIPT_DIR/run-tournament.mjs" "$@"
    ;;
  demo)
    rm -rf .ops-gym
    "$NODE_BIN" "$SCRIPT_DIR/setup-arena.mjs" \
      --arena "footballops-v0" \
      --question "Should the club rotate heavily or push starters through fixture congestion?" \
      --workspace ".ops-gym"
    "$NODE_BIN" "$SCRIPT_DIR/confirm-arena.mjs" --arena "footballops-v0" --workspace ".ops-gym"
    "$NODE_BIN" "$SCRIPT_DIR/add-shock.mjs" \
      --arena "footballops-v0" \
      --type "fixture_congestion" \
      --day "3" \
      --severity "0.55" \
      --label "Midweek cup tie compresses recovery" \
      --workspace ".ops-gym"
    "$NODE_BIN" "$SCRIPT_DIR/create-env.mjs" --arena "footballops-v0" --workspace ".ops-gym"
    "$NODE_BIN" "$SCRIPT_DIR/run-tournament.mjs" \
      --arena "footballops-v0" \
      --run "football-rotation-demo" \
      --rollouts "100" \
      --workspace ".ops-gym"
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
